require_once __DIR__ . '/../../config/bootstrap.php';
require_role('admin');

// 1) Admin nav + user info for header_admin.php
$adminUsername = $_SESSION['username'] ?? 'Admin';
$menu = [
  ['url'=>'index.php',                'icon'=>'bi-speedometer2',      'label'=>'Dashboard'],
  ['url'=>'compensation_videos.php',  'icon'=>'bi-play-btn',           'label'=>'Compensation Videos'],
  ['url'=>'video_manager.php',        'icon'=>'bi-collection-play-fill','label'=>'Manage Quiz'],
  // add more items as needed…
];

// 2) Handle POST: Add or Delete
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if ($_POST['action'] === 'add') {
        // -- Add new video --
        $centre_id  = (int)$_POST['centre_id'];
        $class_date = $_POST['class_date'];
        $video_url  = trim($_POST['video_url']);

        // basic validation
        if ($centre_id && preg_match('/^\d{4}-\d{2}-\d{2}$/', $class_date) && filter_var($video_url, FILTER_VALIDATE_URL)) {
            $ins = $conn->prepare("
              INSERT INTO compensation_videos
                (centre_id, class_date, video_url)
              VALUES (?,?,?)
            ");
            $ins->bind_param('iss', $centre_id, $class_date, $video_url);
            $ins->execute();
            $ins->close();
            $_SESSION['flash'] = ['type'=>'success','msg'=>'Video added successfully'];
        } else {
            $_SESSION['flash'] = ['type'=>'danger','msg'=>'Invalid input—please check all fields.'];
        }
    }
    elseif ($_POST['action'] === 'delete') {
        // -- Delete a video --
        $vid = (int)$_POST['video_id'];
        // Also remove any related quizzes if you have them:
        $conn->prepare("DELETE FROM video_quiz_questions WHERE video_id=?")
             ->bind_param('i', $vid)
             ->execute();
        $del = $conn->prepare("DELETE FROM compensation_videos WHERE id=?");
        $del->bind_param('i', $vid);
        $del->execute();
        $del->close();
        $_SESSION['flash'] = ['type'=>'warning','msg'=>"Video #{$vid} deleted"];
    }

    // Redirect to avoid duplicate submissions
    header('Location: compensation_videos.php');
    exit;
}

// 3) Fetch Centres for dropdown
$centres = $conn->query("SELECT id,name FROM centres ORDER BY name");

// 4) Fetch existing videos (with centre names)
$res = $conn->query("
  SELECT v.id, c.name AS centre, v.class_date, v.video_url
    FROM compensation_videos v
    JOIN centres c ON c.id = v.centre_id
   ORDER BY v.class_date DESC
");

// 5) Grab any flash message
$flash = $_SESSION['flash'] ?? null;
unset($_SESSION['flash']);

// 6) Render header + nav
include __DIR__ . '/../../templates/partials/header_admin.php';
