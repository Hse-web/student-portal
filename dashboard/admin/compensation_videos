<?php
require_once __DIR__.'/../../config/session.php';
require_role('admin');
require_once __DIR__.'/../../config/db.php';

// Handle form submission
if ($_SERVER['REQUEST_METHOD']==='POST') {
  $centre = $_POST['centre_id'];
  $date   = $_POST['class_date'];
  $url    = $_POST['video_url'];
  $i = $conn->prepare("
    INSERT INTO compensation_videos
      (centre_id, class_date, video_url)
    VALUES (?,?,?)
  ");
  $i->bind_param('iss',$centre,$date,$url);
  $i->execute(); $i->close();
  header("Location: compensation_videos.php?added=1");
  exit;
}

// Fetch existing
$res = $conn->query("
  SELECT id, centre_id, class_date, video_url
    FROM compensation_videos ORDER BY class_date DESC
");
?>
